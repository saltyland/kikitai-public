# Supabaseプロジェクトの設定値をコピーして .env.local に貼り付けてください。
# このファイル自体はサンプルです。実値は .env.local に入れます（.env.local はgit管理外）。

# --- アプリ実行に必須 ---
# Supabase ダッシュボード → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- `npm run sync`（DB反映・メール確認OFFの自動化）に使用。任意 ---
# アクセストークン: https://supabase.com/dashboard/account/tokens で発行
SUPABASE_ACCESS_TOKEN=your_personal_access_token
# DBパスワード: プロジェクト作成時に設定したパスワード
SUPABASE_DB_PASSWORD=your_database_password
